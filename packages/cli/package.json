{
  "name": "skillz",
  "version": "0.1.0",
  "description": "CLI for the Open Source Skill Registry — discover, install, and manage AI agent skills",
  "type": "module",
  "license": "MIT",
  "author": "LucaBarden",
  "repository": {
    "type": "git",
    "url": "https://github.com/LucaBarden/Skillz"
  },
  "keywords": [
    "skills",
    "ai",
    "agents",
    "registry",
    "cli",
    "skillz"
  ],
  "bin": {
